PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# MTN Mobile Money
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_CALLBACK_URL=https://your-production-url/api/payments/callback
MOMO_CONSUMER_KEY=your_momo_consumer_key
MOMO_CONSUMER_SECRET=your_momo_consumer_secret
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_API_USER_ID=your_momo_api_user_id

# Email (SMTP or SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="GentsConcerts" <noreply@gentsconcerts.netlify.app>

# Frontend
FRONTEND_URL=https://gentsconcerts.netlify.app

# Push Notifications (Expo)
EXPO_PUSH_ENABLED=true

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# Node Environment
NODE_ENV=production
